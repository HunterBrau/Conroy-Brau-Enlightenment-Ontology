# Reconstructed current-cohort VIAF export for the pilot dataset.
#
# Important note:
# - This is a reproducible re-export query for the current cohort QIDs.
# - It is not guaranteed to be byte-identical to the original manual query
#   used to create 18thcentury_writers_wikidata_viaf.csv, because that
#   original query text was not preserved in the repository.

PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX bd: <http://www.bigdata.com/rdf#>

SELECT
  ?person
  ?personLabel
  ?birth
  ?viaf
WHERE {
  # BEGIN COHORT VALUES
  VALUES ?person {
    wd:Q101638
    wd:Q3185843
  }
  # END COHORT VALUES

  OPTIONAL { ?person wdt:P569 ?birth. }
  OPTIONAL { ?person wdt:P214 ?viaf. }

  SERVICE wikibase:label {
    bd:serviceParam wikibase:language "en,fr".
  }
}
ORDER BY ?personLabel ?birth ?viaf
