# Step 04 split query: language-oriented affiliation evidence.
#
# Use this when the combined enrichment query is too heavy for the endpoint.

PREFIX wd: <http://www.wikidata.org/entity/>
PREFIX wdt: <http://www.wikidata.org/prop/direct/>
PREFIX wikibase: <http://wikiba.se/ontology#>
PREFIX bd: <http://www.bigdata.com/rdf#>

SELECT
  ?person
  ?personLabel
  (GROUP_CONCAT(
    DISTINCT STRAFTER(STR(?nativeLanguage), "/entity/");
    separator=" | "
  ) AS ?native_language_ids)
  (GROUP_CONCAT(
    DISTINCT ?nativeLanguageLabel;
    separator=" | "
  ) AS ?native_language_labels)
  (GROUP_CONCAT(
    DISTINCT STRAFTER(STR(?languagesSpokenWrittenSigned), "/entity/");
    separator=" | "
  ) AS ?spoken_written_language_ids)
  (GROUP_CONCAT(
    DISTINCT ?languagesSpokenWrittenSignedLabel;
    separator=" | "
  ) AS ?spoken_written_language_labels)
  (GROUP_CONCAT(
    DISTINCT STRAFTER(STR(?writingLanguage), "/entity/");
    separator=" | "
  ) AS ?writing_language_ids)
  (GROUP_CONCAT(DISTINCT ?writingLanguageLabel; separator=" | ") AS ?writing_language_labels)
WHERE {
  # BEGIN COHORT VALUES
  VALUES ?person {
    wd:Q101638
    wd:Q3185843
  }
  # END COHORT VALUES

  OPTIONAL { ?person wdt:P103 ?nativeLanguage. }
  OPTIONAL { ?person wdt:P1412 ?languagesSpokenWrittenSigned. }
  OPTIONAL { ?person wdt:P6886 ?writingLanguage. }

  SERVICE wikibase:label {
    bd:serviceParam wikibase:language "en,fr".
  }
}
GROUP BY
  ?person
  ?personLabel
ORDER BY ?personLabel
